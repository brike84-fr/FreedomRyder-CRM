{
  "name": "FR - CSV Lead Import → Supabase",
  "nodes": [
    {
      "id": "csv_webhook",
      "name": "CSV Upload Endpoint",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [0, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "fr-lead-import",
        "responseMode": "lastNode",
        "authentication": "headerAuth",
        "options": {}
      }
    },
    {
      "id": "csv_parse",
      "name": "Parse CSV File",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "operation": "csv",
        "binaryPropertyName": "data"
      }
    },
    {
      "id": "csv_map",
      "name": "Map & Normalize Columns",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nconst mapped = [];\n\nfor (const item of items) {\n  const d = item.json;\n  const fullName = d['Full Name'] || d['Name'] || d['full_name'] || d['name'] || '';\n  const firstName = fullName.split(' ')[0] || '';\n  const email = (d['Email'] || d['email'] || '').trim();\n\n  if (!email || !email.includes('@')) continue;\n\n  mapped.push({\n    json: {\n      full_name: fullName,\n      first_name: firstName,\n      email: email.toLowerCase(),\n      phone: d['Phone'] || d['phone'] || '',\n      state: d['State'] || d['state'] || '',\n      riding_goal: d['Riding Goal'] || d['riding_goal'] || '',\n      height: d['Height'] || d['height'] || '',\n      weight: d['Weight'] || d['weight'] || '',\n      inquiry_type: 'general',\n      status: 'new',\n      temperature: 'medium',\n      source: 'ad',\n      email_sequence_active: true,\n      email_sequence_step: 0\n    }\n  });\n}\n\nif (mapped.length === 0) {\n  throw new Error('No valid rows found in CSV (need at least an email column).');\n}\n\nreturn mapped;"
      }
    },
    {
      "id": "insert_leads",
      "name": "Insert into Supabase",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [750, 300],
      "parameters": {
        "resource": "row",
        "operation": "create",
        "tableId": "leads",
        "fieldsUi": {
          "fieldValues": [
            { "fieldId": "full_name", "fieldValue": "={{ $json.full_name }}" },
            { "fieldId": "first_name", "fieldValue": "={{ $json.first_name }}" },
            { "fieldId": "email", "fieldValue": "={{ $json.email }}" },
            { "fieldId": "phone", "fieldValue": "={{ $json.phone }}" },
            { "fieldId": "state", "fieldValue": "={{ $json.state }}" },
            { "fieldId": "riding_goal", "fieldValue": "={{ $json.riding_goal }}" },
            { "fieldId": "height", "fieldValue": "={{ $json.height }}" },
            { "fieldId": "weight", "fieldValue": "={{ $json.weight }}" },
            { "fieldId": "inquiry_type", "fieldValue": "general" },
            { "fieldId": "status", "fieldValue": "new" },
            { "fieldId": "temperature", "fieldValue": "medium" },
            { "fieldId": "source", "fieldValue": "ad" },
            { "fieldId": "email_sequence_active", "fieldValue": "true" },
            { "fieldId": "email_sequence_step", "fieldValue": "0" }
          ]
        }
      }
    },
    {
      "id": "log_import",
      "name": "Log Import Record",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1000, 300],
      "parameters": {
        "resource": "row",
        "operation": "create",
        "tableId": "ad_imports",
        "fieldsUi": {
          "fieldValues": [
            { "fieldId": "file_name", "fieldValue": "={{ 'csv-import-' + $now.format('yyyy-MM-dd-HHmm') + '.csv' }}" },
            { "fieldId": "lead_count", "fieldValue": "={{ $('Map & Normalize Columns').all().length }}" },
            { "fieldId": "imported_by", "fieldValue": "forrest" }
          ]
        }
      }
    },
    {
      "id": "notify_import",
      "name": "Notify: Import Complete",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1000, 500],
      "parameters": {
        "resource": "row",
        "operation": "create",
        "tableId": "notifications",
        "fieldsUi": {
          "fieldValues": [
            { "fieldId": "type", "fieldValue": "import" },
            { "fieldId": "title", "fieldValue": "CSV Import Complete" },
            { "fieldId": "message", "fieldValue": "={{ $('Map & Normalize Columns').all().length + ' ad leads imported from CSV' }}" }
          ]
        }
      }
    },
    {
      "id": "csv_respond",
      "name": "Respond Success",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1250, 300],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { success: true, rowsImported: $('Map & Normalize Columns').all().length } }}"
      }
    }
  ],
  "connections": {
    "CSV Upload Endpoint": {
      "main": [[{ "node": "Parse CSV File", "type": "main", "index": 0 }]]
    },
    "Parse CSV File": {
      "main": [[{ "node": "Map & Normalize Columns", "type": "main", "index": 0 }]]
    },
    "Map & Normalize Columns": {
      "main": [[{ "node": "Insert into Supabase", "type": "main", "index": 0 }]]
    },
    "Insert into Supabase": {
      "main": [[
        { "node": "Log Import Record", "type": "main", "index": 0 },
        { "node": "Notify: Import Complete", "type": "main", "index": 0 }
      ]]
    },
    "Log Import Record": {
      "main": [[{ "node": "Respond Success", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
